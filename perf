  /**
   * annotations per benchmark / per instruction
   * @param os ostream
   * @param results bench[...]
   */
  template<enum layout::split split = layout::hsplit> requires (split == layout::hsplit)
  inline constexpr void annotate(auto& os, const auto& results) {
    if (results.empty()) {
      return;
    }

    constexpr auto is_num = [](const auto& str) {
      return std::all_of(str.begin(), str.end(), [](const auto c) {
        return std::isdigit(c) or c == '%' or c == '.' or c == '-';
      });
    };

    std::vector<std::map<std::string_view, std::vector<std::string>>> buffers(results.size());
    std::size_t i{};
    for (const auto& [name, data] : results) {
      std::apply([&](const auto&... ts) {
        ([&] {
          auto&& buffer = buffers[i][std::string_view(ts.name())];
          std::size_t n{1u};
          for (const auto& t : ts) {
            if (auto& v = buffers[i]["index"]; v.size() < n) {
              v.push_back(std::format("{}.", n));
            }
            buffer.push_back(std::format("{}", t));
            ++n;
          }
        }(), ...);
      }, data);
      ++i;
    }

    auto&& labels = std::apply([](const auto&... ts) {
      return std::vector{std::string_view{"index"}, std::string_view{ts.name()}...};
    }, results.begin()->data);

    std::vector<std::size_t> len(labels.size(), sizeof("  "));
    for (auto i = 0u; i < labels.size(); ++i) {
      for (auto&& buffer : buffers) {
        verify(buffer.contains(labels[i]) and not buffer[labels[i]].empty());
        const auto size = std::max_element(buffer[labels[i]].begin(), buffer[labels[i]].end(),
          [](const auto& lhs, const auto& rhs) { return lhs.size() < rhs.size(); }
        )->size();
        len[i] = std::max(len[i], size);
      }
    }

    const auto header = [&](const auto& name) {
      log(os, "{}:", name);
      log(os, "\n ");
      for (auto i = 0u; i < len.size(); ++i) {
        log(os, "{:<{}} ", std::format("[{}]", i), len[i]);
      }
      log(os, "\n ");
      for (auto i = 0u; i < len.size(); ++i) {
        log(os, "{:->{}} ", "", len[i]);
      }
      log(os, "\n");
    };

    const auto body = [&](const auto n) {
      verify(not len.empty() and buffers[n].size() == len.size());
      for (auto i = 0u; i < buffers[n].begin()->second.size(); ++i) {
        log(os, " ");
        for (auto l = 0u; l < labels.size(); ++l) {
          verify(buffers[n].contains(labels[l]));
          const auto& str = buffers[n][labels[l]][i];
          if (is_num(str)) {
            log(os, "{:>{}} ", str, len[l]);
          } else {
            log(os, "{:<{}} ", str, len[l]);
          }
        }
        log(os, "\n");
      }
      log(os, "\n");
    };

    const auto footer = [&] {
      for (auto i = 0u; i < labels.size(); ++i) {
        log(os, "{}[{}] {} {}\n", ' ', i, labels[i], misc::legend{labels[i]});
      }
    };

    for (auto i = 0u; i < results.size(); ++i) {
      header(results[i].name);
      body(i);
    }
    footer();
  }

  template<enum layout::split split = layout::hsplit> requires (split == layout::hsplit)
  inline constexpr void annotate(const auto& results) {
    annotate<split>(std::clog, results);
