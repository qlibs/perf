  /**
   * reports per benchmark / per operation
   * @param os ostream
   * @param results bench[...]
   * @param stats... stats
   */
  template<enum layout::split split = layout::hsplit> requires (split == layout::hsplit)
  inline constexpr void report(auto& os, const auto& results, const auto&... stats) requires (sizeof...(stats) > 0u) {
    using data_t = decltype(results[0u].data);

    if (results.empty()) {
      return;
    }

    constexpr auto title = "benchmark";
    constexpr auto size = std::tuple_size_v<data_t> * sizeof...(stats);
    constexpr auto ratio = [](const auto& v, const auto& r) {
      verify(r.max.has_value());
      auto&& slowest = *r.max;
      auto&& value = slowest / v;
      return value;
    };

    auto&& values = [&]<std::size_t... Ns>(std::index_sequence<Ns...>) {
      std::vector<std::tuple<
        typename std::tuple_element_t<Ns % std::tuple_size_v<data_t>, data_t>::value_type...>
      > values{};
      for (const auto& [_, data] : results) {
        std::apply([&](const auto&... ts) {
          values.push_back({
            std::tuple_cat([&](const auto& stat) { return std::tuple{stat(ts)...}; }(stats)...)
          });
        }, data);
      }
      return values;
    }(std::make_index_sequence<size>{});

    auto&& ratios = [&]<std::size_t... Ns>(std::index_sequence<Ns...>) {
      struct ratio { std::optional<double> min{}; std::optional<double> max{}; };
      std::array<ratio, sizeof...(Ns)> ratios{};
      for (const auto& v : values) {
        ([&] {
          if constexpr (requires { double(std::get<Ns>(v)); }) {
            auto&& value = double(std::get<Ns>(v));
            ratios[Ns] = {
              .min = ratios[Ns].min ? std::min(*ratios[Ns].min, value) : value,
              .max = ratios[Ns].max ? std::max(*ratios[Ns].max, value) : value,
            };
          }
        }(), ...);
      }
      return ratios;
    }(std::make_index_sequence<size>{});

    auto&& names = [&] {
      std::vector<std::string> names{title};
      std::transform(results.begin(), results.end(), std::back_inserter(names),
        [](const auto& result) { return std::format("{}", result.name); }
      );
      return names;
    }();

    auto&& lengths = [&] {
      std::array<std::size_t, size + 1u> lengths{
        std::max_element(names.begin(), names.end(),
          [](const auto& lhs, const auto& rhs) { return lhs.size() < rhs.size(); }
        )->size() + 1u
      };

      const auto fill = [&]<std::size_t N> {
        for (const auto& v : values) {
          lengths[N + 1u] = std::max(lengths[N + 1u],
            std::format("{} {}", std::format("({:.2f}x)", ratio(std::get<N>(v), ratios[N])), std::get<N>(v)).size()
          );
        }
      };

      [&]<std::size_t... Ns>(std::index_sequence<Ns...>) {
        (fill.template operator()<Ns>(), ...);
      }(std::make_index_sequence<size>{});

      return lengths;
    }();

    const auto header = [&] {
      log(os, "{:<{}}", title, lengths[0u]);
      for (auto i = 0u; i < size; ++i) {
        log(os, "{:>{}}[{}]", "", lengths[i + 1u] - 1u, i + 1u);
      }
      log(os, "\n");
      for (auto i = 0u; i < lengths.size(); ++i) {
        log(os, "{:->{}}  ", "", lengths[i]);
      }
      log(os, "\n");
    };

    const auto body = [&] {
      std::size_t i{};
      for (const auto& [name, _] : results) {
        log(os, "+ {:<{}}", std::format("{}", name), lengths[0u]);
        std::apply([&](const auto&... vs) {
          std::size_t n{};
          ((log(os, "{:>{}}  ", std::format("{} {}", std::format("({:.2f}x)", ratio(vs, ratios[n])), vs), lengths[n + 1u]), ++n), ...);
        }, values[i]);
        ++i;
        log(os, "\n");
      }
    };

    const auto footer = [&] {
      log(os, "\n(x) relative speedup # {{baseline: 1.00x}}\n");
      std::size_t i{};
      ([&](const auto& stat) {
        std::apply([&](const auto&... ts) {
          (log(os, "[{}] {}({}) {}\n",
            ++i,
            std::string(stat.name()),
            std::string(ts.name()),
            misc::legend{std::string(ts.name())}
          ), ...);
        }, results[0u].data);
      }(stats), ...);
      log(os, "\n");
    };

    header();
    body();
    footer();
  }

