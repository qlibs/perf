            expect(std::vector{1, 2} == plot::math::lin_space(1, 2));
            expect(std::vector{1, 2, 3} == plot::math::lin_space(1, 3));
            expect(std::vector{2, 3, 4, 5, 6, 7} == plot::math::lin_space(2, 7));

            expect(std::vector{1, 2} == plot::math::lin_space(1, 2, 2));
            expect(std::vector{2, 4} == plot::math::lin_space(2, 4, 2));
            expect(std::vector{2, 4, 6, 8, 10} == plot::math::lin_space(2, 10, 5));
            expect(std::vector{5, 10} == plot::math::lin_space(5, 10, 2));
            expect(std::vector{5, 6, 7, 8, 9, 10} == plot::math::lin_space(5, 10, 6));
          };

          "bin"_test = [] mutable {
            expect(std::vector{2ul, 1ul} == plot::math::bin(std::vector{1, 2, 3}, 1, 3, 2));
            expect(std::vector{1ul, 1ul} == plot::math::bin(std::vector{1, 2, 3}, 2, 3, 2));
            expect(std::vector{1ul, 1ul, 1ul} == plot::math::bin(std::vector{1, 2, 3}, 1, 3, 3));
            expect(std::vector{3ul, 2ul} == plot::math::bin(std::vector{1, 2, 3, 4, 5}, 2, 4, 2));
            expect(std::vector{1ul, 1ul, 1ul, 1ul, 1ul} == plot::math::bin(std::vector{1, 2, 3, 4, 5}, 1, 5, 5));
          };
        };

        "gnuplot"_suite = [] mutable {
          using std::literals::string_view_literals::operator""sv;
          plot::gnuplot<fake::subprocess> plt{{}};

          {
            plt.send("cmd1");
            expect(fake::subprocess::cmds.size() > 0u);
            expect("cmd1\n"sv == fake::subprocess::cmds.back());
          }

          {
            plt.send("cmd2");
            expect(fake::subprocess::cmds.size() > 1u);
            expect("cmd2\n"sv == fake::subprocess::cmds.back());
          }

          {
            plt.plot(std::array{1, 2, 3}, std::array{1, 2, 3}, "plot"sv, plot::type::line);
            expect(fake::subprocess::cmds.size() > 2u);
          }

          {
            plt.plot(std::array{1, 2, 3}, std::array{1, 2, 3}, "plots"sv, plot::type::line, plot::type::err);
            expect(fake::subprocess::cmds.size() > 2u);
          }

          {
            plt.show();
            expect(fake::subprocess::cmds.size() > 3u);
            expect("flush\n"sv == fake::subprocess::cmds.back());
          }
        };

        const auto data = fixed_named<"fake.data", std::vector<double>>{std::vector{1., 2., 3.}};
        const fake::metadata<std::string, decltype(data)> results{{.name = "fake.benchmark", .data = {data}}};
        plot::gnuplot<fake::subprocess> plt{{}};

        "hist"_test = [&] mutable {
          plot::hist(plt, results);
          expect(not fake::subprocess::cmds.empty());
        };

        "bar"_test = [&] mutable {
          plot::bar(plt, results);
          expect(not fake::subprocess::cmds.empty());
        };

        "box"_test = [&] mutable {
          plot::box(plt, results);
          expect(not fake::subprocess::cmds.empty());
        };

        "ecdf"_test = [&] mutable {
          plot::ecdf(plt, results);
          expect(not fake::subprocess::cmds.empty());
        };

        "line"_test = [&] mutable {
          const fake::metadata<name<std::string>, decltype(data)> results{
            {.name = name<std::string>{"fake", "fn1", {"0"}}, .data = {data}},
            {.name = name<std::string>{"fake", "fn1", {"1"}}, .data = {data}},
          };
          plot::line(plt, results);
          expect(not fake::subprocess::cmds.empty());
        };
      };
    };
